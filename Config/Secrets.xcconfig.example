// Copy to Config/Secrets.xcconfig (gitignored) or run: ./scripts/setup-secrets.sh
//
// Xcode Cloud: Workflow → Environment → Secret → NOBETECZA_API_KEY
// (ci_scripts/ci_pre_xcodebuild.sh writes Secrets.xcconfig before build)
NOBETECZA_API_KEY = your_nobetecza_api_key_here

// AdMob: çoğu kurulumda kimlikler Xcode’da nobetcim target → Build Settings (project.pbxproj).
// İsterseniz burada tanımlayıp target’taki değerleri boşaltmak yerine tek kaynak yapabilirsiniz; şu an varsayılan kaynak pbxproj’dur.
// ADMOB_APP_ID = ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
// ADMOB_BANNER_ID = ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
// ADMOB_INTERSTITIAL_ID = ca-app-pub-xxxxxxxxxxxxxxxx/wwwwwwwwww
